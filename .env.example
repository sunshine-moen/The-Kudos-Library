# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────────────────
# ≥32 random chars — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://kudos.annualgiving.ubc.ca

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Must match a verified domain in Resend
RESEND_FROM_EMAIL=kudos@mail.annualgiving.ubc.ca

# ── Cron security ─────────────────────────────────────────────────────────────
# ≥32 random chars — must NOT be equal to ADMIN_HEALTH_SECRET
# Vercel cron sends this in the Authorization: Bearer header
CRON_SECRET=

# ── Admin health endpoint ─────────────────────────────────────────────────────
# ≥32 random chars — must NOT be equal to CRON_SECRET
ADMIN_HEALTH_SECRET=

# ── Tenant ────────────────────────────────────────────────────────────────────
# UUID of the Arcadian Grove tenant row in the database
AG_TENANT_ID=

# ── Giphy ─────────────────────────────────────────────────────────────────────
GIPHY_API_KEY=

# ── Monitoring (optional at launch) ──────────────────────────────────────────
SENTRY_DSN=
# Also set for client-side Sentry (must be NEXT_PUBLIC_ prefix):
NEXT_PUBLIC_SENTRY_DSN=

# ── App URL (used for deep-link generation) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=https://kudos.annualgiving.ubc.ca
